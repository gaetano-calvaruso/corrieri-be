meta {
  name: Logout
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Accept: application/json
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", "");
    console.log("Token rimosso.");
  }
}
