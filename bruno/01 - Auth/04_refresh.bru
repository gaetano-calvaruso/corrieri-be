meta {
  name: Refresh Token
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/refresh
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Accept: application/json
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.token);
    console.log("Token aggiornato:", res.body.token);
  }
}
